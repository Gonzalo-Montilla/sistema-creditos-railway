# Copia este archivo a .env y completa con tu correo de pruebas.
# El archivo .env no se sube a Git (está en .gitignore).

# ===== CORREO (para OTP, documentos Habeas Data, pagaré, renovación, retanqueo) =====
# Dejar vacío o usar EMAIL_BACKEND=console para solo ver correos en la consola (no envía).

# Opción A: Ver correos en consola (desarrollo sin SMTP)
# EMAIL_BACKEND=console
# DEFAULT_FROM_EMAIL=noreply@creditos.local

# Opción B: Envío real (Gmail ejemplo)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=tu-correo-pruebas@gmail.com
# EMAIL_HOST_PASSWORD=tu-contraseña-de-aplicacion
# DEFAULT_FROM_EMAIL=tu-correo-pruebas@gmail.com

# Gmail: crear "Contraseña de aplicación" en https://myaccount.google.com/apppasswords
